{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api.py": {
      "excludeFiles": "{frontend/**,test_*.py,train_*.py,audit_*.py,collect_*.py,diagnostic_*.py,debug_*.py,export_*.py}"
    }
  }
}
